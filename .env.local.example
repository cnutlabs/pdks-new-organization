# Backend API URL (the pdks-backend instance)
# Local dev: http://localhost:3000
# Prod: https://your-backend-domain.com
BACKEND_URL=http://localhost:3000

# Seed API key — must EXACTLY match SEED_API_KEY on the backend
# Generate with: openssl rand -hex 32
# Min 32 chars. KEEP THIS SECRET. Never commit.
SEED_API_KEY=replace-me-with-a-64-char-hex-string-from-openssl-rand-hex-32
